export struct SearchResultItem {
    plugin-id: string,
    title: string,
    subtitle: string,
    relevance: float,
    icon: image,
    has-icon: bool,
}

component ResultRow inherits Rectangle {
    height: 48px;
    border-radius: 4px;

    in property <bool> selected: false;
    in property <string> title: "";
    in property <string> subtitle: "";
    in property <image> icon;
    in property <bool> has-icon: false;

    background: selected ? #2a3a5a : transparent;

    ta := TouchArea {
        clicked => {
            root.selected-changed();
        }
    }

    callback selected-changed();

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: start;
        width: parent.width;

        if has-icon : Image {
            width: 32px;
            height: 32px;
            source: icon;
            vertical-stretch: 0;
            horizontal-stretch: 0;
            y: (parent.height - self.height) / 2;
            image-fit: contain;
        }

        VerticalLayout {
            alignment: center;
            spacing: 2px;

            Text {
                text: title;
                color: selected ? #ffffff : #e0e0e0;
                font-size: 14px;
            }

            Text {
                text: subtitle;
                color: #6a6a72;
                font-size: 11px;
            }
        }
    }
}

export component LauncherWindow inherits Window {
    title: "RS Launcher";
    width: 640px;
    background: transparent;
    no-frame: true;

    // Properties
    in-out property <string> search-query: "";
    in-out property <[SearchResultItem]> search-results: [];
    in-out property <int> selected-index: -1;
    in-out property <length> result-viewport-y: 0px;
    in-out property <bool> has-input: false;

    forward-focus: search-input;

    callback key-escape();
    callback search-changed(string);
    callback search-submitted();
    callback result-selected(int);

    function ensure-selected-visible() {
        if root.selected-index < 0 || root.search-results.length == 0 || !root.has-input {
            return;
        }
        let row-height = 50px;
        let selected-y = root.selected-index * row-height;
        let viewport-h = 192px;
        let current-y = -root.result-viewport-y;
        if selected-y < current-y {
            root.result-viewport-y = -selected-y;
        } else if selected-y + row-height > current-y + viewport-h {
            root.result-viewport-y = -(selected-y + row-height - viewport-h);
        }
    }

    // Colors
    property <color> input-bg: #2a2a30;
    property <color> input-text: #e0e0e0;
    property <color> divider-color: #3a3a42;
    property <color> result-bg: #24242a;
    property <color> result-text: #6a6a72;
    property <color> hint-color: #585860;
    property <color> selection-color: #4a90d9;
    property <color> placeholder-color: #6a6a72;

    Rectangle {
        border-radius: 12px;
        background: #1e1e22;
        clip: true;

        VerticalLayout {
            padding: 16px;
            alignment: start;

            // Search input
            Rectangle {
                height: 40px;
                border-radius: 6px;
                background: input-bg;
                clip: true;

                search-input := TextInput {
                    x: 16px;
                    y: 0px;
                    width: parent.width - 32px;
                    height: parent.height;
                    text <=> root.search-query;
                    color: input-text;
                    font-size: 16px;
                    vertical-alignment: center;
                    selection-background-color: selection-color;

                    key-pressed(event) => {
                        if event.text == Key.Escape {
                            root.key-escape();
                            return accept;
                        }
                        // Arrow Up
                        if event.text == "\u{F700}" {
                            if root.selected-index > 0 {
                                root.selected-index -= 1;
                                root.ensure-selected-visible();
                            }
                            return accept;
                        }
                        // Arrow Down
                        if event.text == "\u{F701}" {
                            if root.selected-index < root.search-results.length - 1 {
                                root.selected-index += 1;
                                root.ensure-selected-visible();
                            }
                            return accept;
                        }
                        if event.text == Key.Return && root.selected-index >= 0 {
                            root.result-selected(root.selected-index);
                            return accept;
                        }
                        reject
                    }

                    edited => {
                        root.search-changed(self.text);
                    }

                    accepted => {
                        root.search-submitted();
                    }
                }

                // Placeholder text overlay (only when empty AND not focused)
                if root.search-query == "" && !search-input.has-focus : Text {
                    x: 16px;
                    y: 0px;
                    width: parent.width - 32px;
                    height: parent.height;
                    text: "Type to search...";
                    color: placeholder-color;
                    font-size: 16px;
                    vertical-alignment: center;
                }
            }

            Rectangle { height: 8px; }

            // Divider
            if root.has-input : Rectangle {
                height: 1px;
                background: divider-color;
            }

            if root.has-input : Rectangle { height: 8px; }

            // Result area
            if root.has-input : result-area := Rectangle {
                border-radius: 6px;
                background: result-bg;
                clip: true;
                min-height: 200px;

                if root.search-results.length == 0 : Text {
                    x: 16px;
                    y: 16px;
                    text: "No results";
                    color: result-text;
                    font-size: 13px;
                }

                if root.search-results.length > 0 : Flickable {
                    viewport-y: root.result-viewport-y;

                    VerticalLayout {
                        padding: 4px;
                        spacing: 2px;
                        width: parent.width;

                        for result[idx] in root.search-results : ResultRow {
                            title: result.title;
                            subtitle: result.subtitle;
                            icon: result.icon;
                            has-icon: result.has-icon;
                            selected: idx == root.selected-index;
                            selected-changed => {
                                root.selected-index = idx;
                                root.result-selected(idx);
                            }
                        }
                    }
                }
            }

            if root.has-input : Rectangle { height: 8px; }

            // Hint
            if !root.has-input : Text {
                text: "Ctrl+Alt+Space to toggle  |  Esc to close";
                color: hint-color;
                font-size: 11px;
                horizontal-alignment: center;
            }
        }
    }
}
